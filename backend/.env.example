# LLM — standard OpenAI or any OpenAI-compatible endpoint
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# Set this if using a proxy that needs a Provider header (e.g. Shopee Compass)
# LLM_PROVIDER_HEADER=OpenAI

# Exa.ai for source search
EXA_API_KEY=xxx

# Upstash Redis (optional — app works without it)
UPSTASH_REDIS_URL=

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app
